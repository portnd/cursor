# =============================================================================
# Sentinel Staging (kg.how.co.th) — ใช้บน server: copy เป็น .env ใน ~/kg
# =============================================================================

# --- GHCR (ต้องตรงกับ github.repository_owner) ---
GHCR_IMAGE_PREFIX=ghcr.io/portnd

# --- PostgreSQL ---
POSTGRES_USER=komgrip
POSTGRES_PASSWORD=staging_pg_secret_kg_2024
POSTGRES_DB=komgrip_db
POSTGRES_PORT=5432

# --- MongoDB ---
MONGO_USER=komgrip
MONGO_PASSWORD=staging_mongo_secret_kg_2024
MONGO_DB=komgrip_logs
MONGO_PORT=27017

# --- Redis ---
REDIS_PASSWORD=staging_redis_secret_kg_2024
REDIS_PORT=6379

# --- Backend (JWT, Storage) ---
JWT_SECRET=staging_jwt_secret_change_me_min_32_chars_kg_2024
STORAGE_URL=https://kg.how.co.th

# --- Ports (host) ---
API_PORT=8080
WEB_PORT=3000

# --- Frontend (public API URL สำหรับ browser) ---
NUXT_PUBLIC_API_BASE=https://kg.how.co.th/api/v1
