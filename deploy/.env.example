# =============================================================================
# Sentinel Staging — คัดลอกเป็น .env ใน ~/kg แล้วเติมค่าจริง (ห้าม commit .env)
# =============================================================================

# --- GHCR (ต้องตรงกับ github.repository_owner) ---
GHCR_IMAGE_PREFIX=ghcr.io/YOUR_GITHUB_OWNER

# --- PostgreSQL ---
POSTGRES_USER=komgrip
POSTGRES_PASSWORD=
POSTGRES_DB=komgrip_db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PASSWORD=
REDIS_PORT=6379

# --- Backend (JWT, Storage) ---
JWT_SECRET=
STORAGE_URL=https://kg.how.co.th

# --- Ports (host) ---
API_PORT=8080
WEB_PORT=3000

# --- Frontend (public API URL สำหรับ browser) ---
NUXT_PUBLIC_API_BASE=https://kg.how.co.th/api/v1
