FROM node:18-alpine

# Chromium + deps for headless (E2E, PDF, screenshots)
RUN apk add --no-cache \
    chromium \
    nss \
    freetype \
    harfbuzz \
    ca-certificates \
    ttf-freefont \
    font-noto-emoji

# Tell Playwright/Puppeteer to use system Chromium
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
ENV CHROME_PATH=/usr/bin/chromium-browser

WORKDIR /app

COPY package*.json ./
RUN npm install --legacy-peer-deps --ignore-scripts

COPY . .

# Clear stale Nitro worker sockets (EADDRINUSE when container restarts/hot-reload)
CMD ["sh", "-c", "rm -rf /tmp/nitro && npm run dev"]
