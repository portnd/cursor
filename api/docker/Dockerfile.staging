# =============================================================================
# Sentinel Backend - STAGING DOCKERFILE
# =============================================================================
# Multi-stage build for staging (kg.how.co.th).
# Same as prod: minimal image, non-root user, healthcheck.
# =============================================================================

FROM golang:1.23-alpine AS builder

RUN apk add --no-cache ca-certificates

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG VERSION=dev
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -ldflags="-s -w -X main.Version=${VERSION} -X main.BuildTime=$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    -a -installsuffix cgo \
    -o /app/main \
    ./cmd/server/main.go

RUN ls -lh /app/main

# -----------------------------------------------------------------------------
# Final staging image
# -----------------------------------------------------------------------------
FROM alpine:latest

# Runtime deps + Chromium for PDF export (cost report, quotation, timeline)
RUN apk --no-cache add ca-certificates tzdata wget && \
    apk add --no-cache --repository https://dl-cdn.alpinelinux.org/alpine/v3.19/community \
    chromium nss freetype harfbuzz ttf-freefont

ENV TZ=Asia/Bangkok
ENV APP_ENV=staging
ENV CHROME_PATH=/usr/bin/chromium

RUN addgroup -g 1000 appuser && \
    adduser -D -u 1000 -G appuser appuser

WORKDIR /home/appuser/app

COPY --from=builder /app/main .
COPY --from=builder /build/templates ./templates

RUN chown -R appuser:appuser /home/appuser/app

USER appuser

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:8080/live || exit 1

CMD ["./main"]
